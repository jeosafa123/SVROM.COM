# SUPABASE CONFIGURATION (MANDATORY)
# Configure these in the AI Studio Settings menu to connect your database.

# SUPABASE_URL: The URL of your Supabase project (e.g., https://xyz.supabase.co)
VITE_SUPABASE_URL=

# SUPABASE_ANON_KEY: The public 'anon' key for your Supabase project
VITE_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: The private 'service_role' key (SERVER-SIDE ONLY)
# Required for administrative tasks like creating technicians.
SUPABASE_SERVICE_ROLE_KEY=

# GEMINI_AI_CONFIG
GEMINI_API_KEY=
